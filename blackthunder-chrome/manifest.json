{
  "manifest_version": 3,
  "name": "ThunderCaptcha — Black Thunder CI",
  "description": "No Thunder, No Merge. GitHub の Merge 前にブラックサンダー摂取認証（ThunderCaptcha）を挟む、おやつ系 Chrome 拡張。",
  "version": "0.1.0",
  "icons": {
    "128": "src/assets/logo.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://github.com/*",
    "http://raspberrypi.local/*",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*",
    "https://*.run.app/*"
  ],
  "action": {
    "default_title": "ThunderCaptcha",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "128": "src/assets/logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "run_at": "document_idle",
      "js": [
        "src/content/pr-key.js",
        "src/content/merge-detect.js",
        "src/content/verification.js",
        "src/content/launcher.js",
        "src/content/leaderboard.js",
        "src/content/modal.js",
        "src/content/effects.js",
        "src/content/main.js"
      ],
      "css": ["src/styles/thundercaptcha.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/logo.png",
        "src/assets/chocolate.png",
        "src/assets/black-thunder.svg"
      ],
      "matches": ["https://github.com/*"]
    }
  ]
}
