# Local runtime output
/cache/*
!/cache/.gitkeep
/log/*
!/log/.gitkeep

# Local customizations
/custom/*.zsh
/custom/plugins/*
!/custom/plugins/.gitkeep
/custom/themes/*
!/custom/themes/.gitkeep

# Shell compiled files
*.zwc
*.zwc.old
.zcompdump*

# macOS
.DS_Store

# Python bytecode
__pycache__/
*.pyc
