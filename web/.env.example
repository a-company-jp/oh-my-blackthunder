# ============================================================================
# web/.env.example — the single source of truth for every config value.
# Copy to .env.local for local dev. NEVER commit real secrets.
#
#   PUBLIC  (NEXT_PUBLIC_*) — safe in the browser bundle; baked at BUILD time.
#   SERVER  — only available in Route Handlers / server runtime.
# ============================================================================

# --- Firebase web config (PUBLIC, baked at build) ---------------------------
# From Firebase console > Project settings > Your apps > Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=blackathon
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to "1" to point the browser SDK at the local Firebase emulators.
NEXT_PUBLIC_FIREBASE_USE_EMULATOR=0

# --- GitHub OAuth (CLI/extension Device Flow client) ------------------------
# PUBLIC client id of the GitHub OAuth App used by CLI/extension Device Flow.
NEXT_PUBLIC_GITHUB_OAUTH_CLIENT_ID=
# Same value, available to the server for /api/device proxying if ever needed.
GITHUB_OAUTH_CLIENT_ID=

# SERVER-ONLY. Used only for optional GitHub token introspection / the Firebase
# console GitHub provider. In production this lives in Secret Manager and is
# mounted as a Cloud Run secret-env; never a build arg, never in the image.
GITHUB_OAUTH_CLIENT_SECRET=

# --- firebase-admin (server) ------------------------------------------------
# In production on Cloud Run, firebase-admin uses Application Default Credentials
# via the attached runtime service account — NO JSON key needed. GOOGLE_CLOUD_PROJECT
# is set automatically on Cloud Run.
GOOGLE_CLOUD_PROJECT=blackathon

# LOCAL DEV — two modes:
#
# 1) Against the emulator (default, recommended). `pnpm run emulators` sets these,
#    and firebase-admin needs NO service account at all — just the projectId.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
#
# 2) Against REAL Firestore (no emulator). firebase-admin uses ADC; pick ONE:
#    a) keyless (recommended):  gcloud auth application-default login
#    b) a downloaded service-account key — applicationDefault() reads this path:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
