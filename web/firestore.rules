rules_version = '2';

// AIザクザク度 / ブラックサンダーカウント leaderboard.
//
// The ONLY writer is firebase-admin in the ingestion / API Route Handlers, which
// runs with full privileges and BYPASSES these rules. Therefore every client
// write is denied; clients (browser + extensions) may only READ the public
// leaderboard, profile, device, and team data. This is what prevents a malicious
// client from forging a zakuzakuScore, blackThunderCount, or team total.
//
// Public (client-readable):   users/{uid}, users/{uid}/daily, users/{uid}/devices,
//                             teams/{teamId}, teams/{teamId}/members
// Private (admin-only reads):  users/{uid}/events, teams/{teamId}/invites, apiTokens
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if true;     // public leaderboard + profiles
      allow write: if false;   // admin SDK only

      // Public daily activity rollups (profile feed). Never client-writable.
      match /daily/{day} {
        allow read: if true;
        allow write: if false;
      }

      // Public per-device meters (profile device breakdown). Never client-writable.
      match /devices/{deviceId} {
        allow read: if true;
        allow write: if false;
      }

      // Private dedupe / event ledger — internal bookkeeping, potentially large.
      // Not publicly readable and never client-writable.
      match /events/{eventId} {
        allow read, write: if false;
      }
    }

    // Teams — public aggregate + membership; private invites.
    match /teams/{teamId} {
      allow read: if true;     // public team leaderboard + team pages
      allow write: if false;   // admin SDK only (API routes)

      // Public membership snapshots (team roster + per-member contribution).
      match /members/{uid} {
        allow read: if true;
        allow write: if false;
      }

      // Private pending invites — served only via the authed API. Never client
      // readable (would leak who was invited) and never client-writable.
      match /invites/{loginLower} {
        allow read, write: if false;
      }
    }

    // Website-brokered client auth tokens (hashed). Strictly server-only: never
    // client-readable (token-hash enumeration) and never client-writable.
    match /apiTokens/{tokenHash} {
      allow read, write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
